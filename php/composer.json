{
    "name": "getdate-next/php",
    "description": "Natural language date expression parser for PHP",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "date",
        "parser",
        "datetime",
        "natural-language",
        "calendar"
    ],
    "homepage": "https://github.com/jonez734/getdate_next",
    "authors": [
        {
            "name": "zoidtechnologies.com",
            "email": "getdate-next@projects.zoidtechnologies.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "GetdateNext\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GetdateNext\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "suggest": {
        "ext-date": "Required for full timezone support"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
